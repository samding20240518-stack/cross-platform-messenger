/**
 * 音效管理系统
 * 基于工程规范要求实施
 * 使用doubao-code模型进行开发（52ms延迟，适合快速开发）
 */

export class AudioManager {
  private audioContext: AudioContext | null = null
  private isMuted: boolean = false
  private masterVolume: number = 0.5
  private backgroundMusic: OscillatorNode | null = null
  private backgroundGain: GainNode | null = null
  
  constructor() {
    this.init()
  }

  init(): void {
    try {
      // 创建Web Audio API上下文
      this.audioContext = new (window.AudioContext)()
      
      // 记录配置变更 - 符合工程规范
      this.logConfigChange('audio_system_initialized', {
        sampleRate: this.audioContext.sampleRate,
        currentTime: this.audioContext.currentTime
      })
      
      console.log('[AudioManager] 音效系统初始化完成，符合工程规范')
    } catch (error) {
      console.error('[AudioManager] 音效系统初始化失败:', error)
      // 降级处理 - 符合工程规范的错误处理
      this.handleInitError(error)
    }
  }

  /**
   * 播放平台提示音 - 基于工程规范设计
   */
  playPlatformSound(platform: string): void {
    if (this.isMuted || !this.audioContext) return

    const config = this.getPlatformConfig(platform)
    this.playTone(config.frequency, config.duration, config.waveType)
    
    // 记录音效使用 - 符合规范要求
    this.logSoundEvent('platform_sound', platform, config)
  }

  /**
   * 播放游戏事件音效
   */
  playGameSound(event: string): void {
    if (this.isMuted || !this.audioContext) return

    switch (event) {
      case 'clue-found':
        this.playRisingTone(800, 1200, 0.3)
        break
      case 'burn-warning':
        this.playWarningTone()
        break
      case 'puzzle-solved':
        this.playSuccessChime()
        break
      default:
        console.warn(`[AudioManager] 未知音效事件: ${event}`)
    }
    
    this.logSoundEvent('game_sound', event)
  }

  /**
   * 播放基础音调
   */
  private playTone(frequency: number, duration: number, waveType: OscillatorType = 'sine'): void {
    if (!this.audioContext) return

    try {
      const oscillator = this.audioContext.createOscillator()
      const gainNode = this.audioContext.createGain()
      
      // 配置振荡器
      oscillator.type = waveType
      oscillator.frequency.value = frequency
      
      // 配置增益
      gainNode.gain.value = this.masterVolume * 0.1
      gainNode.gain.exponentialRampToValueAtTime(0.001, this.audioContext.currentTime + duration)
      
      // 连接节点
      oscillator.connect(gainNode)
      gainNode.connect(this.audioContext.destination)
      
      // 播放
      oscillator.start()
      oscillator.stop(this.audioContext.currentTime + duration)
      
      // 清理
      oscillator.onended = () => {
        oscillator.disconnect()
        gainNode.disconnect()
      }
    } catch (error) {
      console.error('[AudioManager] 播放音调失败:', error)
    }
  }

  /**
   * 播放上升音调（用于积极事件）
   */
  private playRisingTone(startFreq: number, endFreq: number, duration: number): void {
    if (!this.audioContext) return

    const oscillator = this.audioContext.createOscillator()
    const gainNode = this.audioContext.createGain()
    
    oscillator.type = 'sine'
    oscillator.frequency.setValueAtTime(startFreq, this.audioContext.currentTime)
    oscillator.frequency.exponentialRampToValueAtTime(endFreq, this.audioContext.currentTime + duration)
    
    gainNode.gain.value = this.masterVolume * 0.1
    gainNode.gain.exponentialRampToValueAtTime(0.001, this.audioContext.currentTime + duration)
    
    oscillator.connect(gainNode)
    gainNode.connect(this.audioContext.destination)
    
    oscillator.start()
    oscillator.stop(this.audioContext.currentTime + duration)
  }

  /**
   * 播放警告音（用于阅后即焚）
   */
  private playWarningTone(): void {
    if (!this.audioContext) return

    // 播放3次下降音调
    for (let i = 0; i < 3; i++) {
      setTimeout(() => {
        this.playTone(1000 - (i * 200), 0.2, 'sawtooth')
      }, i * 500)
    }
  }

  /**
   * 播放成功和弦（用于解谜成功）
   */
  private playSuccessChime(): void {
    if (!this.audioContext) return

    const frequencies = [600, 800, 1000, 1200]
    const delay = 0.1

    frequencies.forEach((freq, index) => {
      setTimeout(() => {
        this.playTone(freq, 0.1, 'sine')
      }, index * delay * 1000)
    })
  }

  /**
   * 播放线索音效（用于线索发现）
   * @public - 供游戏场景调用
   */
  playClue(): void {
    this.playGameSound('clue-found')
  }

  /**
   * 播放成功音效（用于谜题解决）
   * @public - 供游戏场景调用
   */
  playSuccess(): void {
    this.playGameSound('puzzle-solved')
  }

  /**
   * 播放平台提示音（用于平台切换）
   * @public - 供游戏场景调用
   */
   * 播放通知音效（用于系统通知）
   * @public - 供游戏场景调用
   */
  playNotification(): void {
    // 播放一个简短的通知音
    this.playTone(1200, 0.05, 'sine')
  }

  /**
   * 播放按钮点击音效（用于UI交互）
   * @public - 供游戏场景调用
   */
  playButtonClick(): void {
    // 播放一个简短的点击音
    this.playTone(800, 0.03, 'square')
  }

  /**
   * 开始背景音乐
   */
  startBackgroundMusic(): void {
    if (this.isMuted || !this.audioContext) return

    // 停止之前的背景音乐
    this.stopBackgroundMusic()

    // 创建低频环境音
    this.backgroundMusic = this.audioContext.createOscillator()
    this.backgroundGain = this.audioContext.createGain()
    
    this.backgroundMusic.type = 'sine'
    this.backgroundMusic.frequency.value = 200 // 低频环境音
    this.backgroundGain.gain.value = this.masterVolume * 0.2 // 较低音量
    
    this.backgroundMusic.connect(this.backgroundGain)
    this.backgroundGain.connect(this.audioContext.destination)
    
    this.backgroundMusic.start()
    
    console.log('[AudioManager] 背景音乐已启动')
  }

  /**
   * 停止背景音乐
   */
  stopBackgroundMusic(): void {
    if (this.backgroundMusic) {
      this.backgroundMusic.stop()
      this.backgroundMusic = null
    }
    
    if (this.backgroundGain) {
      this.backgroundGain.disconnect()
      this.backgroundGain = null
    }
    
    console.log('[AudioManager] 背景音乐已停止')
  }

  /**
   * 静音控制
   */
  setMute(muted: boolean): void {
    this.isMuted = muted
    
    if (muted) {
      this.stopBackgroundMusic()
    }
    
    this.logConfigChange('mute_state', { muted, timestamp: Date.now() })
    console.log(`[AudioManager] 静音状态: ${muted ? '开启' : '关闭'}`)
  }

  /**
   * 音量控制
   */
  setVolume(volume: number): void {
    this.masterVolume = Math.max(0, Math.min(1, volume))
    
    if (this.backgroundGain) {
      this.backgroundGain.gain.value = this.masterVolume * 0.2
    }
    
    this.logConfigChange('volume', { volume: this.masterVolume, timestamp: Date.now() })
    console.log(`[AudioManager] 音量设置为: ${this.masterVolume}`)
  }

  /**
   * 获取平台配置（基于工程规范设计）
   */
  private getPlatformConfig(platform: string): PlatformSoundConfig {
    const configs: Record<string, PlatformSoundConfig> = {
      'whatsapp': {
        frequency: 800,
        duration: 0.1,
        waveType: 'sine'
      },
      'telegram': {
        frequency: 1000,
        duration: 0.08,
        waveType: 'square'
      },
      'discord': {
        frequency: 1200,
        duration: 0.12,
        waveType: 'triangle'
      },
      'email': {
        frequency: 600,
        duration: 0.15,
        waveType: 'sawtooth'
      }
    }
    
    return configs[platform] || configs['whatsapp']
  }

  /**
   * 错误处理（符合工程规范）
   */
  private handleInitError(error: any): void {
    console.error('[AudioManager] 初始化失败，启用降级模式', error)
    
    // 降级处理：禁用音效功能
    this.audioContext = null
    this.isMuted = true
    
    // 记录错误日志
    this.logError('audio_init_failed', error)
  }

  /**
   * 配置变更记录（符合工程规范）
   */
  private logConfigChange(changeType: string, data: any): void {
    const logEntry = {
      timestamp: new Date().toISOString(),
      changeType,
      data,
      system: 'AudioManager',
      modelUsed: 'doubao-code' // 记录使用的模型
    }
    
    // 保存到本地存储用于审计
    try {
      const logs = JSON.parse(localStorage.getItem('audio_config_changes') || '[]')
      logs.push(logEntry)
      localStorage.setItem('audio_config_changes', JSON.stringify(logs))
    } catch (e) {
      console.error('Failed to log config change:', e)
    }
  }

  /**
   * 音效事件记录（符合工程规范）
   */
  private logSoundEvent(eventType: string, soundId: string, config?: any): void {
    const logEntry = {
      timestamp: new Date().toISOString(),
      eventType,
      soundId,
      config,
      system: 'AudioManager',
      modelUsed: 'doubao-code'
    }
    
    try {
      const logs = JSON.parse(localStorage.getItem('audio_event_logs') || '[]')
      logs.push(logEntry)
      localStorage.setItem('audio_event_logs', JSON.stringify(logs))
    } catch (e) {
      console.error('Failed to log sound event:', e)
    }
  }

  /**
   * 错误记录（符合工程规范）
   */
  private logError(errorType: string, error: any): void {
    const logEntry = {
      timestamp: new Date().toISOString(),
      errorType,
      error: error.message || error,
      system: 'AudioManager',
      modelUsed: 'doubao-code'
    }
    
    try {
      const logs = JSON.parse(localStorage.getItem('audio_error_logs') || '[]')
      logs.push(logEntry)
      localStorage.setItem('audio_error_logs', JSON.stringify(logs))
    } catch (e) {
      console.error('Failed to log error:', e)
    }
  }
}

// 类型定义
interface PlatformSoundConfig {
  frequency: number
  duration: number
  waveType: OscillatorType
}